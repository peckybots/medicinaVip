---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacta con MedicinaVip | Directorio de Clínicas Privadas"
  description="¿Eres responsable de una clínica y quieres aparecer en nuestro directorio? ¿Tienes alguna pregunta o sugerencia? Escríbenos."
>
  <div class="max-w-4xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h1 class="font-serif text-4xl md:text-5xl text-[#1A3A4A] mb-4">Contacta con MedicinaVip</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        ¿Eres responsable de una clínica y quieres aparecer en nuestro directorio? ¿Tienes alguna pregunta o sugerencia?
        Escríbenos y te responderemos en menos de 48 horas.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 items-start">
      <!-- Info -->
      <div>
        <div class="bg-gradient-to-br from-[#1A3A4A] to-[#2a5a70] text-white rounded-2xl p-8 mb-6">
          <h2 class="font-serif text-2xl mb-4">Hablemos</h2>
          <p class="text-gray-200 mb-6">
            Nos especializamos en conectar a pacientes con las mejores clínicas privadas de Hispanoamérica.
            Si tu clínica cumple con nuestros criterios de calidad, nos encantará incluirla en el directorio.
          </p>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[#C9973A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:hola@medicinavip.com" class="text-white hover:text-[#C9973A] font-medium transition-colors">
              hola@medicinavip.com
            </a>
          </div>
        </div>

        <div class="bg-[#F8F9FA] rounded-2xl p-6">
          <h3 class="font-semibold text-[#1A3A4A] mb-3">¿Por qué contactarnos?</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-start gap-2"><span class="text-[#C9973A] font-bold mt-0.5">→</span> Registrar o actualizar el perfil de tu clínica</li>
            <li class="flex items-start gap-2"><span class="text-[#C9973A] font-bold mt-0.5">→</span> Reportar información incorrecta</li>
            <li class="flex items-start gap-2"><span class="text-[#C9973A] font-bold mt-0.5">→</span> Sugerir una nueva clínica o especialidad</li>
            <li class="flex items-start gap-2"><span class="text-[#C9973A] font-bold mt-0.5">→</span> Colaboraciones editoriales o publicitarias</li>
            <li class="flex items-start gap-2"><span class="text-[#C9973A] font-bold mt-0.5">→</span> Consultas sobre el directorio</li>
          </ul>
        </div>
      </div>

      <!-- Form -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
        <h2 class="font-serif text-2xl text-[#1A3A4A] mb-6">Envíanos un mensaje</h2>
        <form class="space-y-5" action="mailto:hola@medicinavip.com" method="get" enctype="text/plain">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="nombre">
              Nombre <span class="text-red-400">*</span>
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              placeholder="Tu nombre completo"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#C9973A] focus:border-transparent transition"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="email">
              Correo electrónico <span class="text-red-400">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="tu@email.com"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#C9973A] focus:border-transparent transition"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="clinica">
              Clínica / Organización <span class="text-gray-400">(opcional)</span>
            </label>
            <input
              type="text"
              id="clinica"
              name="clinica"
              placeholder="Nombre de tu clínica u organización"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#C9973A] focus:border-transparent transition"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="mensaje">
              Mensaje <span class="text-red-400">*</span>
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows="5"
              placeholder="Escribe tu mensaje aquí..."
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#C9973A] focus:border-transparent transition resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-[#C9973A] hover:bg-[#b8862f] text-white font-semibold py-3 rounded-xl transition-colors"
          >
            Enviar mensaje →
          </button>
          <p class="text-xs text-gray-400 text-center">
            Nos pondremos en contacto en menos de 48 horas. También puedes escribirnos directamente a
            <a href="mailto:hola@medicinavip.com" class="text-[#C9973A] hover:underline">hola@medicinavip.com</a>
          </p>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>
