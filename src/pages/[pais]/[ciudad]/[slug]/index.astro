---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ClinicCard from '../../../../components/ClinicCard.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import ShareButtons from '../../../../components/ShareButtons.astro';
import JsonLd from '../../../../components/JsonLd.astro';
import { getCollection, render } from 'astro:content';
import { slugify } from '../../../../utils/slugify';
import { PAIS_INFO } from '../../../../utils/paises';
import { getEspecialidadLabel, ESPECIALIDAD_LABELS } from '../../../../utils/especialidades';

export async function getStaticPaths() {
  const clinics = await getCollection('clinicas', c => !c.data.draft);
  return clinics.map(c => ({
    params: { pais: c.data.pais, ciudad: slugify(c.data.ciudad), slug: c.data.slug },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const paisLabel = PAIS_INFO[data.pais]?.label ?? data.pais;
const ciudadSlug = slugify(data.ciudad);
const ciudadLabel = ciudadSlug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());

// Related clinics (same city or specialty)
const allClinics = await getCollection('clinicas', c => !c.data.draft && c.data.slug !== data.slug);
const related = allClinics
  .filter(c => slugify(c.data.ciudad) === ciudadSlug || c.data.especialidades.some(e => data.especialidades.includes(e)))
  .slice(0, 3);

const especialidadMap = ESPECIALIDAD_LABELS;

const jsonLdSchema = {
  "@context": "https://schema.org",
  "@type": data.camas && data.camas > 100 ? "Hospital" : "MedicalClinic",
  "name": data.name,
  "description": data.descripcion,
  "url": `https://medicinavip.com/${data.pais}/${ciudadSlug}/${data.slug}/`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": data.direccion,
    "addressLocality": ciudadLabel,
    "addressCountry": paisLabel,
  },
  ...(data.telefono && { "telephone": data.telefono }),
  ...(data.web && { "sameAs": data.web }),
  ...(data.email && { "email": data.email }),
  ...(data.imagen && { "image": `https://medicinavip.com${data.imagen}` }),
  ...(data.fundacion && { "foundingDate": String(data.fundacion) }),
  "medicalSpecialty": data.especialidades.map(e => getEspecialidadLabel(e)),
  ...(data.certificaciones && {
    "accreditedBy": data.certificaciones.map(cert => ({
      "@type": "Organization",
      "name": cert,
    }))
  }),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://medicinavip.com/" },
    { "@type": "ListItem", "position": 2, "name": paisLabel, "item": `https://medicinavip.com/${data.pais}/` },
    { "@type": "ListItem", "position": 3, "name": ciudadLabel, "item": `https://medicinavip.com/${data.pais}/${ciudadSlug}/` },
    { "@type": "ListItem", "position": 4, "name": data.name },
  ],
};
---

<BaseLayout
  title={`${data.name} — ${ciudadLabel}, ${paisLabel} | MedicinaVip`}
  description={data.descripcion}
  ogImage={data.imagen}
>
  <JsonLd schema={jsonLdSchema} slot="head" />
  <JsonLd schema={breadcrumbSchema} slot="head" />

  <div class="max-w-5xl mx-auto px-4 py-10">
    <Breadcrumb items={[
      { label: paisLabel, href: `/${data.pais}/` },
      { label: ciudadLabel, href: `/${data.pais}/${ciudadSlug}/` },
      { label: data.name }
    ]} />

    <!-- Hero -->
    <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100 mb-8">
      <!-- Hero image area -->
      <div class="h-56 bg-gradient-to-br from-[#1A3A4A] to-[#2a5a70] flex items-center justify-center relative">
        {data.imagen ? (
          <img src={data.imagen} alt={data.name} class="w-full h-full object-cover" />
        ) : (
          <span class="text-white/20 font-serif text-8xl">{data.name.charAt(0)}</span>
        )}
        {data.featured && (
          <div class="absolute top-4 right-4 bg-[#C9973A] text-white text-xs font-semibold px-3 py-1 rounded-full">
            ⭐ Clínica Destacada
          </div>
        )}
      </div>

      <div class="p-6 md:p-8">
        <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
          <div>
            <h1 class="font-serif text-3xl md:text-4xl text-[#1A3A4A] mb-1">{data.name}</h1>
            <p class="text-gray-500 flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {ciudadLabel}, {paisLabel}
            </p>
          </div>

          <!-- Certifications -->
          {data.certificaciones && (
            <div class="flex flex-wrap gap-2">
              {data.certificaciones.map(cert => (
                <span class="px-3 py-1 border-2 border-[#C9973A] text-[#C9973A] text-xs font-bold rounded-lg">
                  {cert}
                </span>
              ))}
            </div>
          )}
        </div>

        <!-- Specialties -->
        <div class="flex flex-wrap gap-2 mb-6">
          {data.especialidades.map(esp => (
            <a
              href={`/especialidades/${esp}/`}
              class="px-3 py-1 bg-[#1A3A4A]/10 text-[#1A3A4A] rounded-full text-sm font-medium capitalize hover:bg-[#1A3A4A] hover:text-white transition-colors"
            >
              {especialidadMap[esp] || esp}
            </a>
          ))}
        </div>

        <!-- Quick facts -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6 p-4 bg-[#F8F9FA] rounded-xl">
          {data.fundacion && (
            <div class="text-center">
              <div class="text-2xl font-bold text-[#1A3A4A]">{data.fundacion}</div>
              <div class="text-xs text-gray-500">Fundación</div>
            </div>
          )}
          {data.camas && (
            <div class="text-center">
              <div class="text-2xl font-bold text-[#1A3A4A]">{data.camas}</div>
              <div class="text-xs text-gray-500">Camas</div>
            </div>
          )}
          {data.certificaciones && (
            <div class="text-center">
              <div class="text-2xl font-bold text-[#C9973A]">{data.certificaciones.length}</div>
              <div class="text-xs text-gray-500">Certificaciones</div>
            </div>
          )}
          {data.especialidades && (
            <div class="text-center">
              <div class="text-2xl font-bold text-[#1A3A4A]">{data.especialidades.length}</div>
              <div class="text-xs text-gray-500">Especialidades</div>
            </div>
          )}
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8 mb-6">
          <h2 class="font-serif text-2xl text-[#1A3A4A] mb-4">Sobre {data.name}</h2>
          <div class="prose prose-lg max-w-none text-gray-700">
            <Content />
          </div>
        </div>

        <!-- Featured doctors -->
        {data.medicos_destacados && data.medicos_destacados.length > 0 && (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
            <h2 class="font-serif text-2xl text-[#1A3A4A] mb-4">Médicos destacados</h2>
            <ul class="space-y-2">
              {data.medicos_destacados.map(medico => (
                <li class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-[#1A3A4A]/10 flex items-center justify-center">
                    <svg class="w-5 h-5 text-[#1A3A4A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <span class="text-gray-700 font-medium">{medico}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Share -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <ShareButtons title={`${data.name} — ${ciudadLabel}, ${paisLabel}`} />
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1 space-y-6">
        <!-- Contact info -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <h3 class="font-semibold text-[#1A3A4A] mb-4">Información de contacto</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-[#C9973A] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-gray-600">{data.direccion}</span>
            </li>
            {data.telefono && (
              <li class="flex gap-3">
                <svg class="w-5 h-5 text-[#C9973A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <a href={`tel:${data.telefono}`} class="text-[#1A3A4A] hover:text-[#C9973A]">{data.telefono}</a>
              </li>
            )}
            {data.web && (
              <li class="flex gap-3">
                <svg class="w-5 h-5 text-[#C9973A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
                <a href={data.web} target="_blank" rel="noopener noreferrer" class="text-[#1A3A4A] hover:text-[#C9973A] break-all">
                  {data.web.replace(/^https?:\/\//, '')}
                </a>
              </li>
            )}
            {data.email && (
              <li class="flex gap-3">
                <svg class="w-5 h-5 text-[#C9973A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href={`mailto:${data.email}`} class="text-[#1A3A4A] hover:text-[#C9973A]">{data.email}</a>
              </li>
            )}
          </ul>
        </div>

        <!-- Map placeholder -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="h-48 bg-gray-100 flex items-center justify-center text-gray-400">
            <div class="text-center">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
              <p class="text-sm">Ver en Google Maps</p>
              <a
                href={`https://maps.google.com/?q=${encodeURIComponent(data.direccion)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-2 inline-block text-xs text-[#C9973A] hover:underline"
              >
                Abrir mapa →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Related clinics -->
    {related.length > 0 && (
      <div class="mt-12">
        <h2 class="font-serif text-2xl text-[#1A3A4A] mb-6">Clínicas relacionadas</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {related.map(clinica => (
            <ClinicCard
              name={clinica.data.name}
              slug={clinica.data.slug}
              pais={clinica.data.pais}
              ciudad={clinica.data.ciudad}
              especialidades={clinica.data.especialidades}
              certificaciones={clinica.data.certificaciones}
              imagen={clinica.data.imagen}
              descripcion={clinica.data.descripcion}
              featured={clinica.data.featured}
            />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
