---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ClinicCard from '../../../components/ClinicCard.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import JsonLd from '../../../components/JsonLd.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../../utils/slugify';
import { PAIS_INFO } from '../../../utils/paises';

export async function getStaticPaths() {
  const allClinics = await getCollection('clinicas', c => !c.data.draft);

  // Get unique pais+slugifiedCiudad combos
  const combos = [...new Map(
    allClinics.map(c => [
      `${c.data.pais}:${slugify(c.data.ciudad)}`,
      { pais: c.data.pais, ciudadSlug: slugify(c.data.ciudad) }
    ])
  ).values()];

  return combos.map(({ pais, ciudadSlug }) => ({
    params: { pais, ciudad: ciudadSlug },
    props: { paisLabel: PAIS_INFO[pais]?.label ?? pais },
  }));
}

const { pais, ciudad } = Astro.params;
const { paisLabel } = Astro.props as { paisLabel: string };
const ciudadLabel = ciudad!.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

// Match clinics whose slugified ciudad matches the route param
const clinics = await getCollection('clinicas', c => !c.data.draft && c.data.pais === pais && slugify(c.data.ciudad) === ciudad);

const collectionSchema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `Clínicas privadas en ${ciudadLabel}, ${paisLabel}`,
    "description": `Directorio de clínicas privadas y hospitales VIP en ${ciudadLabel}, ${paisLabel}.`,
    "url": `https://medicinavip.com/${pais}/${ciudad}/`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://medicinavip.com/" },
      { "@type": "ListItem", "position": 2, "name": paisLabel, "item": `https://medicinavip.com/${pais}/` },
      { "@type": "ListItem", "position": 3, "name": ciudadLabel, "item": `https://medicinavip.com/${pais}/${ciudad}/` },
    ]
  }
];
---

<BaseLayout
  title={`Clínicas Privadas en ${ciudadLabel}, ${paisLabel} | MedicinaVip`}
  description={`Encuentra las mejores clínicas privadas y hospitales VIP en ${ciudadLabel}, ${paisLabel}. Especialidades, certificaciones JCI y perfiles detallados.`}
>
  <JsonLd schema={collectionSchema} slot="head" />

  <div class="max-w-7xl mx-auto px-4 py-10">
    <Breadcrumb items={[
      { label: paisLabel, href: `/${pais}/` },
      { label: ciudadLabel }
    ]} />

    <h1 class="font-serif text-4xl text-[#1A3A4A] mb-3">
      Clínicas privadas en {ciudadLabel}, {paisLabel}
    </h1>
    <p class="text-gray-600 text-lg mb-10">
      {clinics.length} clínica{clinics.length !== 1 ? 's' : ''} registrada{clinics.length !== 1 ? 's' : ''} en {ciudadLabel}
    </p>

    {clinics.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {clinics.map(clinica => (
          <ClinicCard
            name={clinica.data.name}
            slug={clinica.data.slug}
            pais={clinica.data.pais}
            ciudad={clinica.data.ciudad}
            especialidades={clinica.data.especialidades}
            certificaciones={clinica.data.certificaciones}
            imagen={clinica.data.imagen}
            descripcion={clinica.data.descripcion}
            featured={clinica.data.featured}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-gray-400">
        <p>No hay clínicas registradas en esta ciudad todavía.</p>
      </div>
    )}
  </div>
</BaseLayout>
