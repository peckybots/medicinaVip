---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allClinics = await getCollection('clinicas', c => !c.data.draft);

const especialidades = [
  { slug: 'oncologia', label: 'Oncología', icon: '🎗️', desc: 'Diagnóstico y tratamiento integral del cáncer en los mejores centros oncológicos de Hispanoamérica.' },
  { slug: 'cardiologia', label: 'Cardiología', icon: '❤️', desc: 'Salud cardiovascular avanzada: cardiología clínica, intervencionismo y cirugía cardíaca.' },
  { slug: 'neurologia', label: 'Neurología', icon: '🧠', desc: 'Atención de patologías del sistema nervioso central y periférico por especialistas de alto nivel.' },
  { slug: 'cirugia', label: 'Cirugía', icon: '⚕️', desc: 'Cirugía de alta complejidad, mínimamente invasiva y robótica en los mejores quirófanos.' },
  { slug: 'estetica', label: 'Medicina Estética', icon: '✨', desc: 'Tratamientos de medicina estética y rejuvenecimiento en clínicas certificadas.' },
  { slug: 'fertilidad', label: 'Fertilidad', icon: '🤱', desc: 'Reproducción asistida de alta complejidad: FIV, ICSI, preservación de fertilidad.' },
  { slug: 'ortopedia', label: 'Ortopedia', icon: '🦴', desc: 'Cirugía articular, artroscopia, reemplazo de cadera y rodilla, medicina deportiva.' },
  { slug: 'checkup', label: 'Check-up VIP', icon: '🩺', desc: 'Revisiones médicas integrales y chequeos ejecutivos personalizados.' },
];
---

<BaseLayout
  title="Especialidades Médicas | MedicinaVip"
  description="Explora clínicas privadas por especialidad médica: oncología, cardiología, neurología, fertilidad, ortopedia y más en toda Hispanoamérica."
>
  <div class="max-w-7xl mx-auto px-4 py-10">
    <Breadcrumb items={[{ label: 'Especialidades' }]} />

    <h1 class="font-serif text-4xl text-[#1A3A4A] mb-3">Especialidades médicas</h1>
    <p class="text-gray-600 text-lg mb-10 max-w-2xl">
      Encuentra clínicas privadas especializadas por área médica en toda Hispanoamérica.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {especialidades.map(esp => {
        const count = allClinics.filter(c => c.data.especialidades.includes(esp.slug as any)).length;
        return (
          <a
            href={`/especialidades/${esp.slug}/`}
            class="bg-white rounded-2xl p-6 border border-gray-100 hover:border-[#1A3A4A] hover:shadow-md transition-all group flex flex-col"
          >
            <span class="text-5xl mb-4">{esp.icon}</span>
            <h2 class="font-serif text-xl text-[#1A3A4A] group-hover:text-[#C9973A] transition-colors mb-2">{esp.label}</h2>
            <p class="text-sm text-gray-500 mb-4 flex-1">{esp.desc}</p>
            <span class="text-xs text-[#C9973A] font-semibold">
              {count} clínica{count !== 1 ? 's' : ''} →
            </span>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
