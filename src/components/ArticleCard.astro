---
interface Props {
  title: string;
  slug: string;
  description: string;
  date: string;
  author: string;
  heroImage?: string;
  especialidad?: string;
  pais?: string;
}

const { title, slug, description, date, author, heroImage, especialidad, pais } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden border border-gray-100 flex flex-col">
  <!-- Image -->
  <div class="h-48 bg-gradient-to-br from-[#1A3A4A]/80 to-[#C9973A]/40 flex items-center justify-center overflow-hidden">
    {heroImage ? (
      <img src={heroImage} alt={title} class="w-full h-full object-cover" loading="lazy" />
    ) : (
      <svg class="w-16 h-16 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    )}
  </div>

  <div class="p-5 flex flex-col flex-1">
    <div class="flex gap-2 mb-2">
      {especialidad && (
        <span class="text-xs px-2 py-0.5 bg-[#1A3A4A]/10 text-[#1A3A4A] rounded-full font-medium capitalize">
          {especialidad}
        </span>
      )}
      {pais && (
        <span class="text-xs px-2 py-0.5 bg-[#C9973A]/10 text-[#C9973A] rounded-full font-medium capitalize">
          {pais}
        </span>
      )}
    </div>

    <h3 class="font-serif text-[#1A3A4A] text-lg leading-snug mb-2">
      <a href={`/blog/${slug}/`} class="hover:text-[#C9973A] transition-colors">{title}</a>
    </h3>

    <p class="text-sm text-gray-600 mb-4 line-clamp-3 flex-1">{description}</p>

    <div class="flex items-center justify-between text-xs text-gray-400">
      <span>{author}</span>
      <time datetime={date}>{formattedDate}</time>
    </div>
  </div>
</article>
